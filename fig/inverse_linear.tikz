\begin{tikzpicture}[x=1cm,y=0.5cm]

\def\xmin{0}
\def\xmax{2}
\def\ymin{0}
\def\ymax{2.5}

\useasboundingbox (\xmin,\ymin) rectangle (\xmax,\ymax);

\begin{scope}
  \clip (\xmin,\ymin) rectangle (\xmax,\ymax);

  % Achsen
  \draw[->] (\xmin,0) -- (\xmax,0);
  \draw[->] (0,\ymin) -- (0,\ymax);

  % Funktion (startet bei 0.05 statt 0)
  \draw[domain=0.05:\xmax, samples=200, smooth, thick, red]
    plot ({\x},{1/\x});

\end{scope}

\end{tikzpicture}